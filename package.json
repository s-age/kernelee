{
  "name": "@s-age/kernelee",
  "version": "0.5.0",
  "description": "A message-kernel control framework for TypeScript — core dispatch (KernelSymbol / Verb / KernelBuilder / Kernel / CommandBus) + pipes (Pipe / PipeBuilder / compose / run) + fork (parallel fan-out) + Buffer (observable state) + defineCallable (typed port factory)",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/s-age/kernelee.git"
  },
  "homepage": "https://github.com/s-age/kernelee",
  "keywords": [
    "control-flow",
    "dispatch",
    "message-driven",
    "pipe",
    "forward-only",
    "observable-state",
    "typescript"
  ],
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
